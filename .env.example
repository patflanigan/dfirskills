# FindEvil environment variables — copy to .env and edit

# Evidence root directory. Must contain new/, claims/, processed/, etc.
# Orchestrator creates these subdirs on first run.
EVIDENCE_ROOT=./evidence

# Cognee 1.0 local storage.
# SYSTEM_ROOT_DIRECTORY and DATA_ROOT_DIRECTORY are set per-case by
# orchestrator/main.py to evidence/audit/<CASE_ID>/cognee_{system,data}.
# Do NOT set them here — cognee's internal load_dotenv(override=True) would
# clobber per-case values. To open an archived case in the GUI, use
# scripts/open_case_in_cognee.sh which exports them just-in-time.
COGNEE_VECTOR_STORE=local
COGNEE_GRAPH_STORE=local

# Cognee 1.0 defaults multi-user access control on, which hides the
# orchestrator's ingested data from the unauthenticated GUI. Single-analyst
# workstation — keep off so the GUI sees the case.
ENABLE_BACKEND_ACCESS_CONTROL=false

# Optional: Cognee cloud
# COGNEE_API_KEY=sk-...

# Chisel MCP (path-confined evidence reads — see SKILLS.md §5).
# REQUIRED — agents fail at import time if CHISEL_SECRET is unset.
# Generate a fresh value per deployment, e.g.: openssl rand -hex 24
CHISEL_URL=http://127.0.0.1:3000
CHISEL_SECRET=

# Optional: MCP secret for Volatility-via-Protocol-SIFT
# MCP_SECRET=
